# Neon DB PostgreSQL database connection URL
DATABASE_URL=

# Encryption key for sensitive data (generate a random key)
ENCRYPT_KEY=

# Disable authentication for development or tauri app
VITE_IS_TAURI_APP=false
# Base URL for Better Auth (optional, will be detected automatically)
VITE_BETTER_AUTH_URL=

# Better Auth secret for JWT signing (generate with: openssl rand -base64 32) - Required for production builds
BETTER_AUTH_SECRET=